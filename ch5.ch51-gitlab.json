v991Wo"}],"key":"iFNAl85Mdf"},{"type":"listItem","spread":true,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Test","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"JM5qZEKHzs"}],"key":"zODg1tQElJ"}],"key":"vTUWKskq9P"},{"type":"listItem","spread":true,"position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Release","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"MCuqHViimM"}],"key":"STiwQ1SeOA"}],"key":"aTYAtduqPp"},{"type":"listItem","spread":true,"position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Deploy","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"QnIgUqw2ny"}],"key":"XJ4qIj6tZS"}],"key":"IAEfpClbr6"},{"type":"listItem","spread":true,"position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Operate","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"aQpwEtF491"}],"key":"XaHS3H435v"}],"key":"Kq3tpZoJmN"},{"type":"listItem","spread":true,"position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Monitor","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"ipdYA2dwpG"}],"key":"hH1nHZk8VA"}],"key":"U6iG9yFvuX"}],"key":"eUVm0GQ39k"},{"type":"paragraph","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"text","value":"To implement DevOps, development teams apply different best practices. An important one, is CI/CD which stands for continuos integration and continuos delivery or deployment.","position":{"start":{"line":24,"column":1},"end":{"line":24,"column":1}},"key":"dajW0n6oFx"}],"key":"DQycX4915i"},{"type":"heading","depth":2,"position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"Continuous Integration (CI)","position":{"start":{"line":26,"column":1},"end":{"line":26,"column":1}},"key":"dAgqmYIbcP"}],"identifier":"continuous-integration-ci","label":"Continuous Integration (CI)","html_id":"continuous-integration-ci","implicit":true,"key":"Oye9aErbli"},{"type":"paragraph","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"Continuous Integration encourages developers to integrate their changes into a main branch frequently. Each push is automatically built and tested, reducing integration issues and allowing teams to develop cohesive software more rapidly.","position":{"start":{"line":28,"column":1},"end":{"line":28,"column":1}},"key":"vV2vxFkBVC"}],"key":"DGtGm0jF6H"},{"type":"heading","depth":2,"position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"children":[{"type":"text","value":"Continuous Delivery and Deployment","position":{"start":{"line":30,"column":1},"end":{"line":30,"column":1}},"key":"udFRY0zjnD"}],"identifier":"continuous-delivery-and-deployment","label":"Continuous Delivery and Deployment","html_id":"continuous-delivery-and-deployment","implicit":true,"key":"ybqygvD1FV"},{"type":"paragraph","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"Continuous Delivery extends CI by ensuring that your software can be released to your customers at any moment. It involves automatically deploying all changes to a testing or staging environment after the build stage.","position":{"start":{"line":32,"column":1},"end":{"line":32,"column":1}},"key":"QJS4vdcHpA"}],"key":"K1rKR9OhG8"},{"type":"paragraph","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"text","value":"Continuous Deployment takes this a step further by automatically deploying every change that passes through the pipeline to production, eliminating manual steps in the deployment process.","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"ySJandZisC"}],"key":"y6PYyITViH"},{"type":"heading","depth":2,"position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"How does GitLab CI/CD work?","position":{"start":{"line":36,"column":1},"end":{"line":36,"column":1}},"key":"ho1FxuSwJ5"}],"identifier":"how-does-gitlab-ci-cd-work","label":"How does GitLab CI/CD work?","html_id":"how-does-gitlab-ci-cd-work","implicit":true,"key":"Bgf1Uggeh9"},{"type":"paragraph","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"children":[{"type":"text","value":"Gitlab allow us to define a pipeline in our repository by creating a file named ","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"PeId11I7Pd"},{"type":"inlineCode","value":".gitlab-ci.yml","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"YY47fTykCl"},{"type":"text","value":" in the root of the repository. A pipeline is a set of jobs that are executed in stages everytime a developer pushes a change to the repository. Each job is a script that runs in a separate docker container on a machine that GitLab provides for us named a runner. For example, we can define a job that runs tests, and another job that deploys the project to a server.","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"qW5m7z9eH8"}],"key":"SGb2yjxnlN"},{"type":"paragraph","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"Furthermore, GitLab provides a set of predefined variables that we can use in our scripts to access information about the repository, the pipeline, and the runner. These variables are available in the environment where the job is executed and allow us to define conditional logic in our scripts. This means that we can define different behaviors for our jobs based on the values of these variables. For example, we can define a job that only runs when a specific branch is pushed to the repository.","position":{"start":{"line":40,"column":1},"end":{"line":40,"column":1}},"key":"OFZISykYV9"}],"key":"Vo9XLZigBh"},{"type":"heading","depth":2,"position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"Getting Started with GitLab CI/CD","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"Rmj1OqBCAh"}],"identifier":"getting-started-with-gitlab-ci-cd","label":"Getting Started with GitLab CI/CD","html_id":"getting-started-with-gitlab-ci-cd","implicit":true,"key":"LYXBZegTz2"},{"type":"paragraph","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"text","value":"To get started with GitLab CI/CD, we will now create our first pipeline in a new repository. We will use the GitLab web interface to create a new repository named ","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"m09ZO4kBh0"},{"type":"inlineCode","value":"my-package","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"fsBhSnVdVT"},{"type":"text","value":" that will only contain a README file, and then we will define a simple pipeline in a ","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"ahzQstBQbY"},{"type":"inlineCode","value":".gitlab-ci.yml","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"VxDWM75A7c"},{"type":"text","value":" file.","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"VkNPXmove1"}],"key":"W0Uf4EYHeC"},{"type":"paragraph","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"Go to the ","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"uXtIIt4MLH"},{"type":"link","url":"https://gitlab.com/","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"GitLab website","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"A7cot2p6DB"}],"urlSource":"https://gitlab.com/","key":"kpTxZtOxU1"},{"type":"text","value":" and sign in with your account. Then, click on the “New project” button and select “Create blank project”. Name your project “First Pipeline” and click on the “Create project” button. This will create a new repository in GitLab containing only a README file.","position":{"start":{"line":46,"column":1},"end":{"line":46,"column":1}},"key":"NoDbIkZU8C"}],"key":"xRIknu3qfe"},{"type":"paragraph","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"children":[{"type":"text","value":"Let’s now add a ","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"h3Dpq7n3Xy"},{"type":"inlineCode","value":".gitlab-ci.yml","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"zc23Zme2dm"},{"type":"text","value":" file to the repository. This file will define a pipeline with three jobs. To do this, click on the “Create new file” button in the repository and name the file ","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"fMaj2Fi4fx"},{"type":"inlineCode","value":".gitlab-ci.yml","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"ZaniPuSS51"},{"type":"text","value":". Then, paste the following content into the file and click on the “Commit changes” button.","position":{"start":{"line":48,"column":1},"end":{"line":48,"column":1}},"key":"nlcAuGcQom"}],"key":"QZwY0t07Td"},{"type":"code","lang":"yaml","value":"stages:\n  - build\n  - test\n  - deploy\n\nbuild_job:\n  stage: build\n  script:\n    - echo \"Building the project...\"\n    - echo \"Hello, $GITLAB_USER_LOGIN!\"\n\ntest_job:\n  stage: test\n  script:\n    - echo \"Running tests...\"\n\ndeploy_job:\n  stage: deploy\n  script:\n    - echo \"Deploying to production...\"\n    - echo \"This job deploys something from the $CI_COMMIT_BRANCH branch.\"","key":"X6ZDpZuqRt"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"What to notice","position":{"start":{"line":74,"column":1},"end":{"line":74,"column":1}},"key":"F9EF3aKCSd"}],"key":"RirvcJFp43"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":76,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The ","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"HbOdG0r2WJ"},{"type":"inlineCode","value":"stages","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"E4gn5Bepxl"},{"type":"text","value":" keyword defines the stages of the pipeline. In this example, we have three stages: ","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"sN1dKFIICH"},{"type":"inlineCode","value":"build","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"gx5JDf2eUJ"},{"type":"text","value":", ","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"j9mHETExNw"},{"type":"inlineCode","value":"test","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"sXHfj9oPpF"},{"type":"text","value":", and ","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"mOj7LLFQtn"},{"type":"inlineCode","value":"deploy","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"yVqdFmlbPj"},{"type":"text","value":".","position":{"start":{"line":76,"column":1},"end":{"line":76,"column":1}},"key":"muEBshsSPS"}],"key":"E6aqM8e5DK"}],"key":"WTH6ORlgJW"},{"type":"listItem","spread":true,"position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Each stage contains a job. A job is a script that runs in a separate docker container on a machine that GitLab provides for us named a runner. In this example, we have three jobs: ","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"H5fuej2ECr"},{"type":"inlineCode","value":"build_job","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"r0j3ovutMQ"},{"type":"text","value":", ","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"ZevwdyLXH2"},{"type":"inlineCode","value":"test_job","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"nGKDIzgpoH"},{"type":"text","value":", and ","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"JWYtYiIQOK"},{"type":"inlineCode","value":"deploy_job","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"YnLmvoSKfW"},{"type":"text","value":".","position":{"start":{"line":77,"column":1},"end":{"line":77,"column":1}},"key":"rUrrwyiSq3"}],"key":"K93yAM8CIA"}],"key":"se7QuiB1Hq"},{"type":"listItem","spread":true,"position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The ","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"EcWfXhCs7E"},{"type":"inlineCode","value":"script","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"cXapuASn7V"},{"type":"text","value":" keyword defines the commands that the job will execute. In this example, each job runs a set of commands to demonstrate how to access the predefined variables in the environment where the job is executed.","position":{"start":{"line":78,"column":1},"end":{"line":78,"column":1}},"key":"TGbHEX0YXB"}],"key":"fFC41pgSw7"}],"key":"sd3c17wNCt"}],"key":"ZkN3r4pA3f"}],"class":"hint","key":"T6mV2RnFpd"},{"type":"paragraph","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"children":[{"type":"text","value":"To inspect the pipeline, click on the “Build” button in the repository and then click on the “Pipelines”. You will see the pipeline running with the three stages. You can inspect the logs of each job by clicking first on the stage and then on the job.","position":{"start":{"line":81,"column":1},"end":{"line":81,"column":1}},"key":"TIiCO2oq1g"}],"key":"Hdhy2FAvL4"},{"type":"admonition","children":[{"type":"admonitionTitle","children":[{"type":"text","value":"What to notice","position":{"start":{"line":83,"column":1},"end":{"line":83,"column":1}},"key":"JyUVt84umQ"}],"key":"TLrTY1P5sQ"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"In the logs of each job, you will see the output of the commands that the job executed. You will also see the values of the predefined variables that we used in the commands.","position":{"start":{"line":85,"column":1},"end":{"line":85,"column":1}},"key":"TllLiIX6YR"}],"key":"jdYeIFiFG1"}],"key":"ApLH8kLSkq"}],"key":"JurdVc88SS"}],"class":"hint","key":"HmNCQbdAmC"},{"type":"paragraph","position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"children":[{"type":"text","value":"To gain a better understanding of what is going on in each job, let’s add some commands to the scripts that will show us more information about the environment where the job is executed. For example, we can add commands to show the list of files in the current directory, the output of the ","position":{"start":{"line":88,"column":1},"end":{