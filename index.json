{"version":3,"kind":"Article","sha256":"4b8d20b2a2b5fede552c3bdd1b2eb18c15c8f73fbb4af777153fcc08df005d49","slug":"index","location":"/intro.md","dependencies":[],"frontmatter":{"title":"Welcome to Modern Software Development Practices","content_includes_title":false,"authors":[{"nameParsed":{"literal":"Matias Callara","given":"Matias","family":"Callara"},"name":"Matias Callara","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/mcallara/msdp-book","copyright":"2025","source_url":"https://github.com/mcallara/msdp-book/blob/main/intro.md","edit_url":"https://github.com/mcallara/msdp-book/edit/main/intro.md","exports":[{"format":"md","filename":"intro.md","url":"/build/intro-f990d927ba6cf0dc95ba154c0350373e.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"About the Author","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"nnZJgGkBbO"}],"identifier":"about-the-author","label":"About the Author","html_id":"about-the-author","implicit":true,"key":"pqrkdw2I7U"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Hello. I’m Matias Callara, and for more than 10 years, I’ve been working at the intersection of Machine Learning, Operational Research, and Decision Theory. This should come as no surprise if you consider my academic background. I’m an Industrial Engineer with a Master’s in Optimization and a Ph.D. in Informatics, where I applied Machine Learning to predict behavior in the Cloud Computing Software industry.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"etee5iGhyY"}],"key":"kGEqOdo32O"},{"type":"heading","depth":2,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"How this course was born","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"HCzlEe30jw"}],"identifier":"how-this-course-was-born","label":"How this course was born","html_id":"how-this-course-was-born","implicit":true,"key":"zmOwMnYuyt"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"My role as a tech lead and portfolio manager, responsible for several products, drove me to find and share tools that could help our team work smarter and more effectively. I focused on ensuring these tools were easy for everyone to use and encouraged teams to adopt them.","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"Fls6aXqLYx"}],"key":"OFBhmU1DCz"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"children":[{"type":"text","value":"This course is designed to benefit those with academic backgrounds unrelated to software development. We will explore key topics, from code management with Git to testing and debugging strategies, to equip students with tools and techniques that will hopefully make them enjoy their work, whether alone or as part of a software development team.","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"AjwteiOrCy"}],"key":"ryFcINVuDK"},{"type":"heading","depth":2,"position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"Are Software Development Practices Still Relevant?","position":{"start":{"line":13,"column":1},"end":{"line":13,"column":1}},"key":"ZLhkGeP4MY"}],"identifier":"are-software-development-practices-still-relevant","label":"Are Software Development Practices Still Relevant?","html_id":"are-software-development-practices-still-relevant","implicit":true,"key":"YPiu6x33DK"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"With tools like Generative AI now capable of writing code, it’s natural to question the future of software development and the skills required to succeed in it. No one can predict the future with certainty, so instead of making bold claims, let’s explore this question from first principles.","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"QHUwK0TIMf"}],"key":"NB4KiIB5ms"},{"type":"paragraph","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"Let’s start with a foundational truth: building useful software is about managing complexity. Whether the code is written by a person or generated by an AI, any non-trivial application is a complex system of interlocking parts. This complexity doesn’t disappear; it has to be managed. Software development practices are, at their core, the methods we’ve developed over decades for managing that complexity.","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"n6NYja5Tyr"}],"key":"L3xvHy5ZrV"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"Consider these underlying principles:","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"f6FpntMUIb"}],"key":"OduqyFAPkv"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":21,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Clarity of Intent","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"el3hMuA5xC"}],"key":"qE2iarF8uV"},{"type":"text","value":": Before any code can be created, a human must clearly define the problem and the desired outcome. You must translate a vague need into a precise set of logical instructions. This process of problem decomposition and specifying intent is a fundamental skill of structured thought.","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"MFUUKTqHRq"}],"key":"oLRaYyFCgw"}],"key":"Yq2ltYnM69"},{"type":"listItem","spread":true,"position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"Systematic Verification","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"nqBJJiGQm0"}],"key":"bCickLTt9O"},{"type":"text","value":": An AI can generate code, but who is accountable for it? Ultimately, a human must verify that the code is correct, secure, and reliable. The principles of testing and debugging are not just about finding typos; they are a systematic process for ensuring quality and taking responsibility for the final product.","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"ksrmTXUR3m"}],"key":"tBUG1QxlTg"}],"key":"MvPdqEYORU"},{"type":"listItem","spread":true,"position":{"start":{"line":23,"column":1},"end":{"line":24,"column":1}},"children":[{"type":"paragraph","children":[{"type":"strong","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"Managing Change","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"NjW9fv1qK5"}],"key":"DEufK1tUgp"},{"type":"text","value":": Software is never truly “finished.” It evolves. Version control systems like Git are not just for backing up files; they provide a structured way to manage change over time, collaborate with others, and understand the history of a project. This need to manage evolution is a constant.","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"y5Z2H1ATG3"}],"key":"I74rpgWYUi"}],"key":"b0IcLsLTv7"}],"key":"HyIQFRAP7K"},{"type":"paragraph","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"Viewed from this perspective, learning software development practices is less about learning the transient syntax of a programming language and more about mastering durable principles of structured thinking, quality control, and complexity management. These are skills that retain their value regardless of how the code itself is generated.","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"yaqpFjxRkz"}],"key":"QJeSo9ZNUd"},{"type":"heading","depth":2,"position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"What Do You Hope to Gain?","position":{"start":{"line":27,"column":1},"end":{"line":27,"column":1}},"key":"cWnWSQQdUw"}],"identifier":"what-do-you-hope-to-gain","label":"What Do You Hope to Gain?","html_id":"what-do-you-hope-to-gain","implicit":true,"key":"VkFZYFFeog"},{"type":"paragraph","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"children":[{"type":"text","value":"Given the uncertainties we’ve just discussed, it’s more important than ever to be clear about your own learning objectives. So, before we dive in, I encourage you to pause and reflect on what brought you here.","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"XBVo897qXT"}],"key":"j9SARuyrGy"},{"type":"paragraph","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"Please answer the following questions for yourself:","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"tWyo8KGtZp"}],"key":"HMj0QDLIZz"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":33,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"What is my primary expectation for this course?","position":{"start":{"line":33,"column":1},"end":{"line":33,"column":1}},"key":"RyIvS7DVki"}],"key":"LkZY6EuSmT"}],"key":"jOxulcVGgl"},{"type":"listItem","spread":true,"position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"What kind of structured thinking skills do I hope to develop?","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"a7z9MNEuII"}],"key":"mbsdfWgp3S"}],"key":"HbLbou1yEu"},{"type":"listItem","spread":true,"position":{"start":{"line":35,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"What do I want to be able to build or competently manage after this course?","position":{"start":{"line":35,"column":1},"end":{"line":35,"column":1}},"key":"JachmbRiCN"}],"key":"zWpSVNIgCv"}],"key":"Jo8GBkzwNO"}],"key":"p4VCpX7qKI"},{"type":"heading","depth":2,"position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"text","value":"Table of Contents","position":{"start":{"line":37,"column":1},"end":{"line":37,"column":1}},"key":"zQNj4pPcoP"}],"identifier":"table-of-contents","label":"Table of Contents","html_id":"table-of-contents","implicit":true,"key":"hWW41CqQ0p"},{"type":"block","children":[{"type":"list","children":[{"type":"listItem","children":[{"type":"link","url":"/","internal":true,"children":[{"type":"text","value":"Modern Software Development Practices","key":"KYlQc4rb9m"}],"urlSource":"/","key":"Ul8ldO64OS"}],"key":"PS998JQ7mB"},{"type":"listItem","children":[{"type":"link","url":"/ch1/ch10","internal":true,"children":[{"type":"text","value":"1 Introduction to Version Control","key":"QsKyBBaAO9"}],"urlSource":"/ch1/ch10","dataUrl":"/ch1.ch10.json","protocol":"file","key":"SxtreRbEG6"},{"type":"list","children